{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "**/.env*",
    "**/tsconfig*.json",
    "**/vitest.config.*",
    "**/playwright.config.*"
  ],
  "tasks": {
    "generate:aliases": {
      "outputs": ["vite.aliases.json", "tsconfig.base.json", "tsconfig.json", "vitest.config.ts"]
    },
    "generate:barrels": {
      "outputs": ["src/**/index.ts"]
    },
    "build": {
      "dependsOn": ["^generate:aliases", "generate:barrels", "^build"],
      "outputs": ["dist/**", "src/**/*.d.ts"]
    },
    "clean": {
      "outputs": []
    },
    "dev": {
      "cache": false
    },
    "fix": {},
    "format": {},
    "lint:fix": {},
    "lint": {
      "dependsOn": ["^build"]
    },
    "test:coverage:report": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**", "test-results/**"]
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "outputs": ["test-results/**", "playwright-report/**"]
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "outputs": ["test-results/**"]
    },
    "test:unit": {
      "dependsOn": ["^build"],
      "outputs": ["test-results/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["test-results/**"]
    },
    "type-check": {}
  }
}
