{
  "name": "@template-app/starter-web",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/vite:build",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "{projectRoot}/dist",
        "root": "{projectRoot}",
        "configFile": "{projectRoot}/vite.config.ts"
      }
    },
    "serve": {
      "executor": "@nx/vite:dev-server",
      "persistent": true,
      "options": {
        "buildTarget": "{projectName}:build"
      }
    },
    "preview": {
      "executor": "@nx/vite:preview-server",
      "options": {
        "buildTarget": "{projectName}:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "eslintConfig": "{projectRoot}/eslint.config.js",
        "lintFilePatterns": [
          "{projectRoot}/src/**/*.{ts,tsx,js,jsx}",
          "{projectRoot}/*.{ts,tsx,js,jsx}"
        ]
      }
    },
    "lint:fix": {
      "executor": "@nx/eslint:lint",
      "options": {
        "eslintConfig": "{projectRoot}/eslint.config.js",
        "lintFilePatterns": [
          "{projectRoot}/src/**/*.{ts,tsx,js,jsx}",
          "{projectRoot}/*.{ts,tsx,js,jsx}"
        ],
        "fix": true
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --check .",
        "cwd": "{projectRoot}"
      },
      "cache": true,
      "inputs": [
        "default",
        "{projectRoot}/.prettierignore",
        "{workspaceRoot}/.prettierrc"
      ]
    },
    "format:fix": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --write .",
        "cwd": "{projectRoot}"
      }
    },
    "type-check": {
      "executor": "@nx/js:tsc",
      "options": {
        "main": "src/main.tsx",
        "tsConfig": "tsconfig.json",
        "outputPath": "{projectRoot}/dist",
        "noEmit": true
      }
    },
    "test": {
      "executor": "@nx/vite:test",
      "options": {
        "configFile": "{projectRoot}/vitest.config.ts"
      }
    },
    "test:coverage": {
      "executor": "@nx/vite:test",
      "outputs": [
        "{projectRoot}/coverage/**"
      ],
      "options": {
        "configFile": "{projectRoot}/vitest.config.ts",
        "coverage": true
      }
    },
    "test:e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec playwright install && pnpm test:e2e",
        "cwd": "{projectRoot}"
      }
    },
    "test:all": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx test",
          "nx test:e2e"
        ],
        "parallel": true
      }
    },
    "validate:static": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx lint",
          "nx format:check",
          "nx type-check"
        ],
        "parallel": true
      }
    },
    "validate:quick": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx validate:static",
          "nx test"
        ],
        "parallel": false
      }
    },
    "validate:full": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx validate:static",
          "nx test:all"
        ],
        "parallel": false
      }
    },
    "storybook": {
      "executor": "@nx/storybook:storybook",
      "options": {
        "configDir": ".storybook",
        "browserTarget": "{projectName}:build",
        "compodoc": false
      }
    },
    "build-storybook": {
      "executor": "@nx/storybook:build",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "configDir": ".storybook",
        "browserTarget": "{{projectName}}:build",
        "outputPath": "{projectRoot}/dist/storybook"
      }
    }
  }
}
