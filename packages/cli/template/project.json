{
  "name": "@vite-powerflow/starter",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/vite:build",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist"
      }
    },
    "serve": {
      "executor": "@nx/vite:dev-server",
      "persistent": true,
      "options": {
        "buildTarget": "{{projectName}}:build"
      }
    },
    "preview": {
      "executor": "@nx/vite:preview-server",
      "options": {
        "buildTarget": "{{projectName}}:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["src/**/*.{ts,tsx,js,jsx}", "*.{ts,tsx,js,jsx}"]
      }
    },
    "lint:fix": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["src/**/*.{ts,tsx,js,jsx}", "*.{ts,tsx,js,jsx}"],
        "fix": true
      }
    },
    "type-check": {
      "executor": "@nx/js:tsc",
      "options": {
        "main": "src/main.tsx",
        "tsConfig": "tsconfig.json",
        "outputPath": "dist",
        "noEmit": true
      }
    },
    "test": {
      "executor": "@nx/vite:test",
      "options": {
        "config": "vitest.config.ts"
      }
    },
    "test:coverage": {
      "executor": "@nx/vite:test",
      "outputs": ["{projectRoot}/coverage/**"],
      "options": {
        "config": "vitest.config.ts",
        "coverage": true
      }
    },
    "test:e2e": {
      "executor": "@nx/playwright:playwright",
      "options": {
        "config": "playwright.config.ts"
      }
    },
    "test:all": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["nx test", "nx test:e2e"],
        "parallel": true
      }
    },
    "validate:static": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["nx lint", "nx format:check", "nx type-check"],
        "parallel": true
      }
    },
    "validate:quick": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["nx validate:static", "nx test"],
        "parallel": false
      }
    },
    "validate:full": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["nx validate:static", "nx test:all"],
        "parallel": false
      }
    },
    "storybook": {
      "executor": "@nx/storybook:storybook",
      "options": {
        "configDir": ".storybook",
        "browserTarget": "{{projectName}}:build",
        "compodoc": false
      }
    },
    "build-storybook": {
      "executor": "@nx/storybook:build",
      "outputs": ["{options.outputPath}"],
      "options": {
        "configDir": ".storybook",
        "browserTarget": "{{projectName}}:build",
        "outputPath": "dist/storybook"
      }
    }
  }
}
