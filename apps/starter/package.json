{
  "name": "@vite-powerflow/starter",
  "private": true,
  "version": "2.1.0",
  "description": "Vite PowerFlow starter template - Monorepo with web app",
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "web:dev": "nx serve @vite-powerflow/starter-web",
    "build": "nx run-many --target=build --all",
    "test": "nx run-many --target=test --all",
    "test:e2e": "nx run-many --target=test:e2e --all",
    "lint": "nx run-many --target=lint --all",
    "type-check": "nx run-many --target=type-check --all",
    "clean": "nx run-many --target=clean --all"
  },
  "devDependencies": {
    "nx": "21.5.2"
  }
}
