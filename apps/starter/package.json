{
  "name": "@vite-powerflow/starter",
  "private": true,
  "version": "2.1.0",
  "description": "Vite PowerFlow starter template - Monorepo with web app",
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "web:dev": "pnpm --filter @vite-powerflow/starter-web dev",
    "dev": "pnpm --filter @vite-powerflow/starter-web dev",
    "build": "nx run-many --targets=build --all",
    "lint": "nx run-many --targets=lint --all",
    "format": "nx run-many --targets=format --all",
    "format:fix": "nx run-many --targets=format:write --all",
    "type-check": "nx run-many --targets=type-check --all",
    "test": "nx run-many --targets=test --all"
  },
  "devDependencies": {
    "nx": "21.5.2"
  }
}
